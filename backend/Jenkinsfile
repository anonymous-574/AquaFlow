pipeline {
    agent any

    options {
        timestamps()
    }

    parameters {
        booleanParam(name: 'BUILD_AND_PUSH_IMAGES', defaultValue: false, description: 'Build app images and push to ECR')
        booleanParam(name: 'DEPLOY_INFRA', defaultValue: false, description: 'Run Terraform apply/destroy from infra/terraform')
        booleanParam(name: 'RUN_POST_DEPLOY_JOBS', defaultValue: true, description: 'After terraform apply, run DB seeder once and trigger Spark once')
        choice(name: 'TF_ACTION', choices: ['apply', 'destroy'], description: 'Terraform action when DEPLOY_INFRA=true')
        string(name: 'AWS_REGION', defaultValue: 'ap-south-1', description: 'AWS region for ECR/Terraform')
        string(name: 'ECR_REGISTRY', defaultValue: '', description: 'ECR registry, e.g. 123456789012.dkr.ecr.ap-south-1.amazonaws.com')
        string(name: 'TF_WORKING_DIR', defaultValue: 'infra/terraform', description: 'Terraform root directory')
        string(name: 'TERRAFORM_EXTRA_ARGS', defaultValue: '', description: 'Extra terraform args (e.g. -var-file=terraform.tfvars)')
    }

    environment {
        SCANNER_HOME = tool 'SonarQubeScanner'
        DEBIAN_FRONTEND = 'noninteractive'
    }

    stages {
        stage('Prepare Build Tools') {
            steps {
                sh '''
                apt-get update
                apt-get install -y --no-install-recommends \
                    python3 python3-pip python3-venv \
                    nodejs npm \
                    awscli \
                    unzip \
                    curl \
                    jq

                # Install Terraform
                if ! command -v terraform >/dev/null 2>&1; then
                  curl -fsSL https://releases.hashicorp.com/terraform/1.9.8/terraform_1.9.8_linux_amd64.zip -o /tmp/terraform.zip
                  unzip -o /tmp/terraform.zip -d /usr/local/bin
                fi

                # Install Docker CLI manually (Bulletproof method)
                if ! command -v docker >/dev/null 2>&1; then
                  curl -fsSL https://download.docker.com/linux/static/stable/x86_64/docker-24.0.7.tgz -o /tmp/docker.tgz
                  tar xzvf /tmp/docker.tgz -C /tmp
                  mv /tmp/docker/docker /usr/bin/docker
                  chmod +x /usr/bin/docker
                  rm -rf /tmp/docker /tmp/docker.tgz
                fi

                python3 --version
                node --version
                npm --version
                aws --version
                terraform version
                docker --version
                jq --version
                '''
            }
        }

        stage('Run Backend Tests') {
            steps {
                sh '''
                python3 -m venv .venv
                . .venv/bin/activate

                pip install -r backend/auth_service/requirements.txt
                pip install -r backend/supplier_service/requirements.txt
                pip install -r backend/booking_service/requirements.txt
                pip install -r backend/gamification_service/requirements.txt
                pip install -r backend/iot_analytics_service/requirements.txt
                pip install pandas pyarrow
                pip install pytest pytest-cov

                export FLASK_ENV=testing
                export PYTHONPATH=./backend

                python -m compileall \
                  backend/auth_service \
                  backend/supplier_service \
                  backend/booking_service \
                  backend/gamification_service \
                  backend/iot_analytics_service

                python -m pytest backend/tests/ --cov=backend/ --cov-report=xml
                '''
            }
        }

        stage('Build Frontend') {
            steps {
                sh '''
                npm --prefix frontend ci
                npm --prefix frontend run build
                '''
            }
        }

        stage('SonarQube Security Scan') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                    $SCANNER_HOME/bin/sonar-scanner \
                      -Dsonar.projectKey=water-conservation-app \
                      -Dsonar.sources=. \
                      -Dsonar.python.coverage.reportPaths=coverage.xml \
                      -Dsonar.javascript.lcov.reportPaths=frontend/coverage/lcov.info \
                      -Dsonar.typescript.lcov.reportPaths=frontend/coverage/lcov.info
                    '''
                }
            }
        }

        stage('Build & Push Images in Parallel') {
            when {
                expression { return params.BUILD_AND_PUSH_IMAGES }
            }
            steps {
                script {
                    // 1. Fail fast if no registry is provided
                    if (!env.ECR_REGISTRY) {
                        error("ECR_REGISTRY is required when BUILD_AND_PUSH_IMAGES=true")
                    }

                    // 2. Log in to AWS ECR once before starting parallel jobs
                    sh 'aws ecr get-login-password --region "$AWS_REGION" | docker login --username AWS --password-stdin "$ECR_REGISTRY"'

                    // 3. Define all your images and their folder paths
                    def images = [
                        'frontend': './frontend',
                        'api_gateway': './backend/api_gateway',
                        'db_seeder': './backend',
                        'auth_service': './backend/auth_service',
                        'supplier_service': './backend/supplier_service',
                        'booking_service': './backend/booking_service',
                        'gamification_service': './backend/gamification_service',
                        'iot_analytics_service': './backend/iot_analytics_service',
                        'spark_job': './analytics'
                    ]

                    // 4. Create a map of tasks to run in parallel
                    def parallelBuilds = [:]

                    images.each { imageName, buildPath ->
                        parallelBuilds[imageName] = {
                            // Build and push immediately for each image
                            sh """
                            docker build -t ${ECR_REGISTRY}/${imageName}:latest ${buildPath}
                            docker push ${ECR_REGISTRY}/${imageName}:latest
                            """
                        }
                    }

                    // 5. Execute all 9 tasks at the same time
                    parallel parallelBuilds
                }
            }
        }

        stage('Terraform Deploy') {
            when {
                expression { return params.DEPLOY_INFRA }
            }
            steps {
                sh '''
                aws sts get-caller-identity

                cd "$TF_WORKING_DIR"
                terraform init -input=false

                if [ "$TF_ACTION" = "destroy" ]; then
                  terraform destroy -auto-approve -input=false -var="aws_region=$AWS_REGION" $TERRAFORM_EXTRA_ARGS
                else
                  terraform plan -input=false -out=tfplan -var="aws_region=$AWS_REGION" $TERRAFORM_EXTRA_ARGS
                  terraform apply -input=false -auto-approve tfplan
                fi
                '''
            }
        }

        stage('Post Deploy: Seed DB and Run Spark Once') {
            when {
                allOf {
                    expression { return params.DEPLOY_INFRA }
                    expression { return params.RUN_POST_DEPLOY_JOBS }
                    expression { return params.TF_ACTION == 'apply' }
                }
            }
            steps {
                sh '''
                cd "$TF_WORKING_DIR"

                OUTPUT_JSON="$(terraform output -json)"
                CLUSTER_NAME="$(echo "$OUTPUT_JSON" | jq -r '.ecs_cluster_name.value')"
                SEED_TASK_DEF="$(echo "$OUTPUT_JSON" | jq -r '.db_seeder_task_definition_arn.value')"
                SPARK_TASK_DEF="$(echo "$OUTPUT_JSON" | jq -r '.spark_task_definition_arn.value')"
                ECS_SG_ID="$(echo "$OUTPUT_JSON" | jq -r '.ecs_security_group_id.value')"
                SUBNETS_CSV="$(echo "$OUTPUT_JSON" | jq -r '.private_subnet_ids.value | map("\\"" + . + "\\"") | join(",")')"
                SG_JSON="\\"$ECS_SG_ID\\""
                NETWORK_CONF="awsvpcConfiguration={subnets=[$SUBNETS_CSV],securityGroups=[$SG_JSON],assignPublicIp=DISABLED}"

                run_and_wait() {
                  local label="$1"
                  local task_def="$2"
                  local task_arn
                  local exit_code

                  task_arn="$(aws ecs run-task \
                    --cluster "$CLUSTER_NAME" \
                    --launch-type FARGATE \
                    --task-definition "$task_def" \
                    --network-configuration "$NETWORK_CONF" \
                    --query 'tasks[0].taskArn' \
                    --output text)"

                  if [ -z "$task_arn" ] || [ "$task_arn" = "None" ]; then
                    echo "Failed to start $label task"
                    exit 1
                  fi

                  echo "$label task started: $task_arn"
                  aws ecs wait tasks-stopped --cluster "$CLUSTER_NAME" --tasks "$task_arn"
                  exit_code="$(aws ecs describe-tasks --cluster "$CLUSTER_NAME" --tasks "$task_arn" --query 'tasks[0].containers[0].exitCode' --output text)"

                  if [ "$exit_code" != "0" ]; then
                    echo "$label failed with exit code $exit_code"
                    aws ecs describe-tasks --cluster "$CLUSTER_NAME" --tasks "$task_arn" --output table
                    exit 1
                  fi

                  echo "$label completed successfully"
                }

                run_and_wait "db-seeder" "$SEED_TASK_DEF"
                run_and_wait "spark-once" "$SPARK_TASK_DEF"
                '''
            }
        }
    }
}
