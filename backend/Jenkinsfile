pipeline {
    agent any

    environment {
        SCANNER_HOME = tool 'SonarQubeScanner'
        DEBIAN_FRONTEND = 'noninteractive'
    }

    stages {
        stage('Prepare Build Tools') {
            steps {
                sh '''
                if ! command -v python3 >/dev/null 2>&1; then
                  apt-get update
                  apt-get install -y python3 python3-pip python3-venv
                fi

                if ! command -v node >/dev/null 2>&1; then
                  apt-get update
                  apt-get install -y nodejs npm
                fi

                python3 --version
                pip3 --version
                node --version
                npm --version
                '''
            }
        }

        stage('Run Backend Tests') {
            steps {
                sh '''
                pip3 install -r backend/auth_service/requirements.txt
                pip3 install -r backend/supplier_service/requirements.txt
                pip3 install -r backend/booking_service/requirements.txt
                pip3 install -r backend/gamification_service/requirements.txt
                pip3 install -r backend/iot_analytics_service/requirements.txt
                pip3 install pandas pyarrow
                pip3 install pytest pytest-cov
                
                export FLASK_ENV=testing
                export PYTHONPATH=./backend

                python3 -m compileall \
                  backend/auth_service \
                  backend/supplier_service \
                  backend/booking_service \
                  backend/gamification_service \
                  backend/iot_analytics_service
                
                python3 -m pytest backend/tests/ --cov=backend/ --cov-report=xml
                '''
            }
        }

        stage('Build Frontend') {
            steps {
                sh '''
                cd frontend
                npm ci
                npm run build
                '''
            }
        }

        stage('SonarQube Security Scan') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                    $SCANNER_HOME/bin/sonar-scanner \
                      -Dsonar.projectKey=water-conservation-app \
                      -Dsonar.sources=. \
                      -Dsonar.python.coverage.reportPaths=coverage.xml \
                      -Dsonar.javascript.lcov.reportPaths=frontend/coverage/lcov.info \
                      -Dsonar.typescript.lcov.reportPaths=frontend/coverage/lcov.info \
                      -Dsonar.host.url=http://sonarqube:9000
                    '''
                }
            }
        }
    }
}
